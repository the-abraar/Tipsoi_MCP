# ── Your Gemini key (server-side only — never given to users) ───────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# ── Gateway config ──────────────────────────────────────────────────────────
GATEWAY_KEYS_FILE=./keys.json
# Max tool-call rounds per message (runaway-cost guard)
GATEWAY_MAX_TOOL_ITERS=6
# Python used to launch the MCP server subprocess (default: python)
# MCP_PYTHON=python

# ── Escalation backend (passed through to the MCP server) ───────────────────
SUPPORT_TICKET_MODE=off
# CLICKUP_API_TOKEN=pk_...
# CLICKUP_LIST_ID=901800000000
SUPPORT_PHONE=+8809638017170
SUPPORT_EMAIL=support@inovacetech.com
