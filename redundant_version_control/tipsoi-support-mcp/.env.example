# ── Transport ──────────────────────────────────────────────────────────────
# stdio (default, for Claude Desktop) or http (remote connector)
TIPSOI_TRANSPORT=stdio
# Port for http mode
PORT=8000

# ── Human-support contacts (shown on escalation) ────────────────────────────
SUPPORT_PHONE=+8809638017170
SUPPORT_EMAIL=support@inovacetech.com

# ── Escalation backend ──────────────────────────────────────────────────────
# auto | clickup_api | webhook | off
#   auto      → clickup_api if token+list set, else webhook if set, else off
#   clickup_api → file a task via ClickUp's documented REST API
#   webhook   → POST the ticket JSON to your own endpoint (Zapier/Make/n8n)
#   off       → don't submit; return the formatted ticket for manual filing
SUPPORT_TICKET_MODE=auto

# ── ClickUp API mode ────────────────────────────────────────────────────────
# Personal API token from ClickUp → Settings → Apps (starts with pk_)
CLICKUP_API_TOKEN=
# Numeric List ID that the support form creates tasks in.
# Find it: open the form's destination List in ClickUp; the URL ends in /li/<LIST_ID>,
# or call GET https://api.clickup.com/api/v2/team to walk space→folder→list.
CLICKUP_LIST_ID=
# OPTIONAL: map ticket fields to ClickUp custom-field UUIDs to populate them
# natively (otherwise everything goes into the task description).
# GET https://api.clickup.com/api/v2/list/<LIST_ID>/field to discover the UUIDs.
# CLICKUP_CUSTOM_FIELDS={"client_name":"<uuid>","reported_by":"<uuid>","email":"<uuid>","task_type":"<uuid>","reported_date":"<uuid>"}

# ── Webhook mode (alternative to a ClickUp token) ───────────────────────────
# SUPPORT_TICKET_WEBHOOK=https://hooks.zapier.com/hooks/catch/xxxx/yyyy
