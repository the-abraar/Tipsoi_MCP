# Copy to .env and fill in. Do NOT commit the real .env.

# --- Required: service account credentials ---
TIPSOI_EMAIL=ilham@example.com
TIPSOI_PASSWORD=your-password-here

# --- Optional: defaults so report tools don't need IDs every call ---
# Find these via the list_workplaces tool once connected.
TIPSOI_OFFICE_ID=4397
TIPSOI_COMPANY_ID=4146

# --- Optional: overrides ---
# TIPSOI_BASE_URL=https://hrm.tipsoi.pro/inovace-client/api/v1
# TIPSOI_TZ_OFFSET_HOURS=6        # Asia/Dhaka (BST, UTC+6)
# TIPSOI_TRANSPORT=stdio          # or 'http' for remote connector mode
